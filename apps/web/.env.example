# Local development with Spotlight (no Sentry account required)
# Run: npx @spotlightjs/spotlight
SENTRY_SPOTLIGHT=1
NEXT_PUBLIC_SENTRY_SPOTLIGHT=1
SENTRY_DSN=https://spotlight@local/0
NEXT_PUBLIC_SENTRY_DSN=https://spotlight@local/0

# Production / staging (replace placeholder DSN after creating a Sentry project)
# SENTRY_ORG=dfn-au
# SENTRY_PROJECT=dfn-web
# SENTRY_DSN=https://examplePublicKey@o0.ingest.us.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.us.sentry.io/0
# SENTRY_AUTH_TOKEN=

# PostHog analytics and build-time source map uploads
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
# POSTHOG_PROJECT_ID=
# POSTHOG_API_KEY=

# Sanity Content Lake and embedded Studio
NEXT_PUBLIC_SANITY_PROJECT_ID=bt057kcd
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-10
NEXT_PUBLIC_SANITY_STUDIO_URL=/admin/studio
NEXT_PUBLIC_SANITY_PREVIEW_URL=/
# SANITY_API_READ_TOKEN=
